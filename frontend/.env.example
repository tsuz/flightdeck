# WebSocket endpoint configuration for the frontend.
#
# Precedence at runtime: WS_URL (Docker) > VITE_WS_URL (build) > auto-detect.
# If none is set, the app auto-detects: wss:// when the page is served over
# HTTPS, ws:// otherwise, against the page's own host at /ws.
#
# VITE_WS_URL is baked in at build time (npm run build). Use it for local/dev
# builds. For the published Docker image, set WS_URL in docker-compose instead
# (it is injected at container start, no rebuild needed):
#
#   frontend:
#     environment:
#       WS_URL: wss://your-host/ws
#
# VITE_WS_URL=wss://your-host/ws
